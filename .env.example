# ============================================================
#  SecureMatAgent — Environment Variables
#  Copy this file to .env and adjust values as needed.
# ============================================================

# ----- Developer mode ----------------------------------------
# Set to true when running Python directly on the host (no Docker).
# This auto-patches OLLAMA_BASE_URL → localhost and QDRANT_HOST → localhost.
LOCAL_DEV=true

# ----- Ollama -----------------------------------------------
# Docker containers use host.docker.internal; local dev uses localhost.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TEMPERATURE=0.1
OLLAMA_TIMEOUT=120

# ----- Qdrant ------------------------------------------------
# Docker service name inside compose network; use localhost for local dev.
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ----- Vector collection ------------------------------------
COLLECTION_NAME=securematagent_docs

# ----- Embeddings -------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# ----- Chunking / Retrieval ---------------------------------
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5
MEMORY_WINDOW=5

# ----- FastAPI ----------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ----- Streamlit --------------------------------------------
STREAMLIT_PORT=8501

# ----- Data -------------------------------------------------
DATA_DIR=data/documents

# ----- Observability / Tracing ------------------------------
# Leave LANGCHAIN_API_KEY blank to use local tracing (default).
# Set it to your LangSmith key to enable remote tracing.
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=securematagent
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com  # default

# Write trace events to traces/<session_id>.jsonl in addition to memory
TRACE_TO_FILE=true
